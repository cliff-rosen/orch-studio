{
  "kind": "item",
  "kind_plural": "items",
  "description": "The atomic unit of an ongoing-system workspace. Rename and customize during contracts-drafting (e.g., to 'task', 'contact', 'note').",
  "schema": {
    "type": "object",
    "required": ["id", "title", "state", "created_at"],
    "properties": {
      "id": {
        "type": "string",
        "pattern": "^item-\\d{3,}$"
      },
      "title": {
        "type": "string",
        "minLength": 1,
        "maxLength": 200
      },
      "detail": {
        "type": "string"
      },
      "state": {
        "enum": ["inbox", "active", "waiting", "someday", "done", "dropped"]
      },
      "created_at": {
        "type": "string",
        "format": "date-time"
      },
      "completed_at": {
        "type": "string",
        "format": "date-time"
      },
      "waiting_on": {
        "type": "string",
        "description": "Free text: who or what is blocking. Required when state == waiting."
      }
    }
  },
  "states": ["inbox", "active", "waiting", "someday", "done", "dropped"],
  "initial_state": "inbox",
  "transitions": [
    { "from": "inbox", "to": "active" },
    { "from": "inbox", "to": "someday" },
    { "from": "inbox", "to": "dropped" },
    { "from": "active", "to": "waiting", "guard": "waiting_on must be set" },
    { "from": "active", "to": "done" },
    { "from": "active", "to": "someday" },
    { "from": "active", "to": "dropped" },
    { "from": "waiting", "to": "active" },
    { "from": "someday", "to": "active" },
    { "from": "someday", "to": "dropped" }
  ],
  "invariants": [
    "If state == done, completed_at must be set.",
    "If state == waiting, waiting_on must be set."
  ],
  "id_field": "id",
  "title_field": "title"
}
