{
  "name": "{{ view_name }}",
  "view_type": "dashboard",
  "config": {
    "tiles": [
      {
        "type": "goal-banner",
        "source": "goal.json"
      },
      {
        "type": "workflow-strip",
        "source": "workflow.json",
        "show_counts": true
      },
      {
        "type": "view-embed",
        "view": "{{ primary_view_name }}"
      },
      {
        "type": "counts",
        "kinds": ["{{ kind }}"],
        "group_by": "state"
      }
    ]
  }
}
