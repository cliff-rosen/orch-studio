{
  "kind": "{{ kind_singular }}",
  "kind_plural": "{{ kind_plural }}",
  "description": "{{ what_this_kind_is }}. Hierarchical: instances can reference a parent of the same kind.",
  "schema": {
    "type": "object",
    "required": ["id", "{{ title_field }}"],
    "properties": {
      "id": {
        "type": "string",
        "pattern": "^{{ id_prefix }}-\\d{3,}$"
      },
      "{{ title_field }}": {
        "type": "string",
        "minLength": 1
      },
      "parent": {
        "type": ["string", "null"],
        "description": "Reference to parent {{ kind_singular }} id. Null = root."
      },
      "order": {
        "type": "integer",
        "description": "Sort order among siblings."
      }
    }
  },
  "id_field": "id",
  "title_field": "{{ title_field }}",
  "references": [
    { "field": "parent", "kind": "{{ kind_singular }}" }
  ]
}
