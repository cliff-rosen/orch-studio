{
  "kind": "{{ kind_singular }}",
  "kind_plural": "{{ kind_plural }}",
  "description": "{{ what_this_kind_is }}",
  "schema": {
    "type": "object",
    "required": ["id", "{{ title_field }}", "state", "created_at"],
    "properties": {
      "id": {
        "type": "string",
        "pattern": "^{{ id_prefix }}-\\d{3,}$"
      },
      "{{ title_field }}": {
        "type": "string",
        "minLength": 1
      },
      "state": {
        "enum": ["{{ state_1 }}", "{{ state_2 }}", "{{ state_3 }}"]
      },
      "created_at": { "type": "string", "format": "date-time" },
      "completed_at": { "type": "string", "format": "date-time" }
    }
  },
  "states": ["{{ state_1 }}", "{{ state_2 }}", "{{ state_3 }}"],
  "initial_state": "{{ state_1 }}",
  "transitions": [
    { "from": "{{ state_1 }}", "to": "{{ state_2 }}" },
    { "from": "{{ state_2 }}", "to": "{{ state_3 }}" }
  ],
  "invariants": [
    "If state == {{ terminal_state }}, completed_at must be set."
  ],
  "id_field": "id",
  "title_field": "{{ title_field }}"
}
