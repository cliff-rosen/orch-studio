{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "lws://meta-schema/meta",
  "title": "Workspace Meta",
  "description": "Identity and lifecycle state for a Living Workspace. The plugin reads this on startup to know what kind of workspace it's looking at.",
  "type": "object",
  "required": ["workspace_id", "created_at", "status", "meta_schema_version"],
  "properties": {
    "workspace_id": {
      "type": "string",
      "description": "Stable identifier for this workspace."
    },
    "title": {
      "type": "string",
      "description": "Display name."
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "last_modified": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "enum": [
        "goal-defining",
        "substrate-selecting",
        "contracts-drafting",
        "operating",
        "wrapping-up",
        "archived"
      ],
      "description": "Current phase in the workspace lifecycle state machine."
    },
    "substrate_type": {
      "enum": [
        "ongoing-system",
        "single-deliverable",
        "pipeline",
        "tracker",
        "project-plan",
        "hybrid"
      ],
      "description": "Selected during bootstrap; determines which starter pack loads."
    },
    "current_stage": {
      "type": ["string", "null"],
      "description": "Reference to a workflow.json stage name (used during operating)."
    },
    "domain_hint": {
      "type": "string",
      "description": "Free-text tag, e.g. 'competitive-analysis', 'master-todo'."
    },
    "meta_schema_version": {
      "type": "string"
    }
  }
}
